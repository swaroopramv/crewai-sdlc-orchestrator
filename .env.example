# LLM Provider (local-first via Ollama — no API keys required)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Optional cloud providers (leave blank to use local Ollama)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

LLM_TEMPERATURE=0.3

# Pipeline
MAX_RETRIES=3
RETRY_DELAY_SECONDS=30
MAX_TRIAGE_LOOPS=5
APPROVAL_TIMEOUT_HOURS=24

# Storage (SQLite by default, swap path for PostgreSQL URL)
ARTIFACT_DB_PATH=artifacts.db
CHECKPOINT_DB_PATH=checkpoints.db

# Notifications (optional — leave blank to disable)
CHAT_BOT_TOKEN=
CHAT_ROOM_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# CI System (replace with real endpoint)
CI_BASE_URL=https://ci.example.com
CI_API_TOKEN=

# Issue Tracker
ISSUE_TRACKER_URL=https://issues.example.com
ISSUE_TRACKER_API_TOKEN=
